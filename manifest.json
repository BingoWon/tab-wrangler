{
  "manifest_version": 3,
  "name": "Bin Duplicate Tab Closer",
  "version": "0.0.9",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_appDesc__"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "webRequest",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
