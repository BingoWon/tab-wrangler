{
  "manifest_version": 3,
  "name": "Tab Wrangler",
  "version": "0.1.0",
  "description": "Extension prevents duplicate tabs by focusing on already opened tabs in the same window.",
  "background": {
    "service_worker": "js/background.js"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "incognito": "spanning"
}
